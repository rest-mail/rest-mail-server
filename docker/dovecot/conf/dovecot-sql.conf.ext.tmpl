# Dovecot SQL configuration for ${MAIL_DOMAIN}

driver = pgsql
connect = host=${DB_HOST} dbname=${DB_NAME} user=${DB_USER} password=${DB_PASS}

# Password query: authenticate a user
# Expects {BLF-CRYPT} prefix on password hash
password_query = \
  SELECT address AS user, password, \
    5000 AS userdb_uid, 5000 AS userdb_gid, \
    CONCAT('/var/mail/vhosts/', d.name, '/', m.local_part) AS userdb_home \
  FROM mailboxes m \
  JOIN domains d ON m.domain_id = d.id \
  WHERE m.address = '%u' AND m.active = true AND d.active = true

# User query: look up user info
user_query = \
  SELECT CONCAT('/var/mail/vhosts/', d.name, '/', m.local_part) AS home, \
    5000 AS uid, 5000 AS gid, \
    CONCAT('*:bytes=', m.quota_bytes) AS quota_rule \
  FROM mailboxes m \
  JOIN domains d ON m.domain_id = d.id \
  WHERE m.address = '%u' AND m.active = true AND d.active = true

# Iterate query: list all users (for doveadm)
iterate_query = \
  SELECT address AS user FROM mailboxes WHERE active = true
